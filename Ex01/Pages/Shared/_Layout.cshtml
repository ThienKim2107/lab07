<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">

                <!-- Logo -->
                <a class="navbar-brand fw-bold" asp-page="/Index">🎓 SchoolApp</a>

                <!-- Toggle mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")"
                               asp-page="/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Students") == true ? "active" : "")"
                               asp-page="/Students/Index">Students</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Courses") == true ? "active" : "")"
                               asp-page="/Courses/Index">Courses</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Instructors") == true ? "active" : "")"
                               asp-page="/Instructors/Index">Instructors</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Enrollments") == true ? "active" : "")"
                               asp-page="/Enrollments/Index">Enrollments</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Departments") == true ? "active" : "")"
                               asp-page="/Departments/Index">Departments</a>
                        </li>

                    </ul>

                    <!-- Right side (optional) -->
                    <span class="navbar-text text-light small">
                        SE Lab 7
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top text-muted mt-5">
        <div class="container text-center py-3">
            © 2025 - SchoolApp | SE Lab 7 - FIT TDTU
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>