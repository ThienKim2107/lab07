@page
@model Ex01.Pages.Courses.IndexModel

<h2>Courses</h2>

<p>
    <a asp-page="Create" class="btn btn-primary">+ Add Course</a>
</p>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Credits</th>
            <th>Department</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Courses)
        {
            <tr>
                <td>@c.CourseID</td>
                <td>@c.Title</td>
                <td>@c.Credits</td>
                <td>@c.Department?.Name</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@c.CourseID" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-page="Delete" asp-route-id="@c.CourseID" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>