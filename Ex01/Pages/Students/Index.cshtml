@page
@model Ex01.Pages.Students.IndexModel

<h2>Students</h2>

<p>
    <a asp-page="Create" class="btn btn-primary">+ Add Student</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Full Name</th>
            <th>Enrollment Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Students)
        {
            <tr>
                <td>@s.StudentID</td>
                <td>@s.FullName</td>
                <td>@s.EnrollmentDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@s.StudentID">Edit</a> |
                    <a asp-page="Delete" asp-route-id="@s.StudentID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>