@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">🎓 School Management System</h1>
    <p class="lead">Manage Students, Courses, and Enrollments</p>
</div>

<hr />

<div class="row text-center">

    <div class="col-md-4">
        <div class="card shadow p-3 mb-4">
            <h3>Students</h3>
            <p>Manage student information</p>
            <a asp-controller="Students" asp-action="Index" class="btn btn-primary">
                Go to Students
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow p-3 mb-4">
            <h3>Courses</h3>
            <p>Manage courses and departments</p>
            <a asp-controller="Courses" asp-action="Index" class="btn btn-success">
                Go to Courses
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow p-3 mb-4">
            <h3>Enrollments</h3>
            <p>Manage enrollments</p>
            <a asp-controller="Enrollments" asp-action="Index" class="btn btn-warning">
                Go to Enrollments
            </a>
        </div>
    </div>

</div>

<div class="row text-center">

    <div class="col-md-6">
        <div class="card shadow p-3 mb-4">
            <h3>Departments</h3>
            <p>Manage departments</p>
            <a asp-controller="Departments" asp-action="Index" class="btn btn-info">
                Go to Departments
            </a>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow p-3 mb-4">
            <h3>Instructors</h3>
            <p>Manage instructors</p>
            <a asp-controller="Instructors" asp-action="Index" class="btn btn-dark">
                Go to Instructors
            </a>
        </div>
    </div>

</div>